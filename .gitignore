# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store

# Generated / fetched data — regenerable from your own rides, can be large
tiles/
data/tiles/
godot/data/tiles/
*.bin
*.gpx
route.json
world.json
heights.bin
features.json
osm_cache.json
osm_buildings_cache.json
osm_graph_cache.json
.bake_osm_route.json
# per-route working/backup data dirs
godot/data_*/

# Godot
godot/.godot/
godot/.import/
*.translation
# exported binaries (regenerable; large)
build/
# export_presets.cfg IS tracked — the P6 macOS export config (no signing secrets)

# Avatar 3D models are NEVER committed/shipped — drop-in only, kept local.
# The loader (Main.gd _spawn_avatar) falls back to the procedural Tron rider when
# absent, so a release built without a model is safe by default. Only ship a model
# you have the rights to distribute. README.md in assets/ IS tracked (the contract).
godot/assets/*.glb
godot/assets/*.gltf
godot/assets/*.import
# Blender working files repo-wide (often hold not-for-distribution source meshes)
*.blend
*.blend1
# Textures extracted from the (never-shipped) avatar models travel with them
godot/assets/*.jpg
godot/assets/*.jpeg
godot/assets/*.png
# Harness screenshot output (root-level test renders) + personal ride recordings
/*.png
/*.tcx
